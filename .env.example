# Required: Fernet encryption key for the secrets store.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ROOTSTOCK_SECRET_KEY=

# Path inside the container where the homelab repo is mounted (default: /homelab).
# HOMELAB_REPO_PATH=/homelab

# Optional git remote URL for pushing the homelab repo off-site.
# HOMELAB_REMOTE_URL=git@github.com:you/homelab.git

# CORS allowed origins. Required for local development only.
# The production Docker stack serves the frontend via nginx on the same origin,
# so CORS is not needed there. Uncomment for local dev:
# CORS_ORIGINS=http://localhost:5173

# Log level: debug, info, warning, error (default: info)
# LOG_LEVEL=info
